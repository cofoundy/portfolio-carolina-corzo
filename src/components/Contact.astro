---
import { siteConfig } from "../config";
---

<footer id="contacto" class="py-20 sm:py-28" style="background: var(--color-surface);">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <!-- Section header -->
    <div class="reveal mb-12">
      <p class="font-mono text-xs tracking-[0.3em] uppercase mb-3" style="color: var(--color-accent);">
        Conectemos
      </p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl tracking-wider" style="color: var(--color-surface-light);">
        CONTACTO
      </h2>
      <div class="gold-shimmer mt-4 w-24 mx-auto"></div>
    </div>

    <!-- Social links -->
    <div class="reveal flex flex-wrap justify-center gap-6 sm:gap-8 mb-12">
      {siteConfig.social.email && (
        <a
          href={`mailto:${siteConfig.social.email}`}
          class="group flex items-center gap-2 font-mono text-xs tracking-widest uppercase transition-all duration-300"
          style="color: var(--color-surface-light); opacity: 0.6;"
          onmouseover="this.style.opacity='1'; this.style.color='var(--color-accent)'"
          onmouseout="this.style.opacity='0.6'; this.style.color='var(--color-surface-light)'"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M22 4L12 13L2 4"/>
          </svg>
          Email
        </a>
      )}
      {siteConfig.social.linkedin && (
        <a
          href={siteConfig.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-2 font-mono text-xs tracking-widest uppercase transition-all duration-300"
          style="color: var(--color-surface-light); opacity: 0.6;"
          onmouseover="this.style.opacity='1'; this.style.color='var(--color-accent)'"
          onmouseout="this.style.opacity='0.6'; this.style.color='var(--color-surface-light)'"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          LinkedIn
        </a>
      )}
      {siteConfig.social.instagram && (
        <a
          href={siteConfig.social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-2 font-mono text-xs tracking-widest uppercase transition-all duration-300"
          style="color: var(--color-surface-light); opacity: 0.6;"
          onmouseover="this.style.opacity='1'; this.style.color='var(--color-accent)'"
          onmouseout="this.style.opacity='0.6'; this.style.color='var(--color-surface-light)'"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>
          </svg>
          Instagram
        </a>
      )}
      {siteConfig.social.muso && (
        <a
          href={siteConfig.social.muso}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-2 font-mono text-xs tracking-widest uppercase transition-all duration-300"
          style="color: var(--color-surface-light); opacity: 0.6;"
          onmouseover="this.style.opacity='1'; this.style.color='var(--color-accent)'"
          onmouseout="this.style.opacity='0.6'; this.style.color='var(--color-surface-light)'"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 18V5l12-2v13"/>
            <circle cx="6" cy="18" r="3"/>
            <circle cx="18" cy="16" r="3"/>
          </svg>
          Muso Credits
        </a>
      )}
      {siteConfig.social.spotify && (
        <a
          href={siteConfig.social.spotify}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-2 font-mono text-xs tracking-widest uppercase transition-all duration-300"
          style="color: var(--color-surface-light); opacity: 0.6;"
          onmouseover="this.style.opacity='1'; this.style.color='var(--color-accent)'"
          onmouseout="this.style.opacity='0.6'; this.style.color='var(--color-surface-light)'"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 15c3-1 5-1 8 0"/>
            <path d="M7 12c4-1.5 6-1.5 10 0"/>
            <path d="M6 9c5-2 7-2 12 0"/>
          </svg>
          Spotify
        </a>
      )}
    </div>

    <!-- Divider -->
    <div class="gold-shimmer w-full mb-8"></div>

    <!-- Footer credits -->
    <div class="reveal">
      <p class="font-mono text-xs tracking-wide" style="color: var(--color-surface-light); opacity: 0.3;">
        &copy; {new Date().getFullYear()} Carolina Corzo Martínez
      </p>
      <p class="font-mono text-xs tracking-wide mt-1" style="color: var(--color-surface-light); opacity: 0.2;">
        Desarrollado por <a href="https://cofoundy.dev" target="_blank" rel="noopener noreferrer" class="link-underline" style="color: var(--color-accent); opacity: 0.5;">Cofoundy</a>
      </p>
    </div>
  </div>
</footer>
