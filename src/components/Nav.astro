---
import { siteConfig } from "../config";
---

<!-- Fixed top bar -->
<nav id="nav-bar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background: transparent;">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#" class="font-mono text-sm tracking-widest uppercase" style="color: var(--color-accent);">
      CC
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {["Créditos", "Trayectoria", "Playlist", "Sobre Mí", "Contacto"].map((item) => (
        <a
          href={`#${item.toLowerCase().replace(/\s/g, '-').normalize('NFD').replace(/[\u0300-\u036f]/g, '')}`}
          class="font-mono text-xs tracking-widest uppercase link-underline transition-colors duration-200"
          style="color: var(--color-surface-light); opacity: 0.7;"
          onmouseover="this.style.opacity='1'"
          onmouseout="this.style.opacity='0.7'"
        >
          {item}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button id="mobile-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menú">
      <span class="block w-5 h-px transition-all duration-200" style="background: var(--color-surface-light);"></span>
      <span class="block w-5 h-px transition-all duration-200" style="background: var(--color-surface-light);"></span>
      <span class="block w-3 h-px transition-all duration-200" style="background: var(--color-accent);"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden px-6 pb-6">
    <div class="flex flex-col gap-4 pt-4" style="border-top: 1px solid var(--color-primary-light);">
      {["Créditos", "Trayectoria", "Playlist", "Sobre Mí", "Contacto"].map((item) => (
        <a
          href={`#${item.toLowerCase().replace(/\s/g, '-').normalize('NFD').replace(/[\u0300-\u036f]/g, '')}`}
          class="mobile-nav-link font-mono text-sm tracking-widest uppercase"
          style="color: var(--color-surface-light); opacity: 0.7;"
        >
          {item}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  // Scroll: add bg to nav
  const nav = document.getElementById('nav-bar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 100) {
      nav!.style.background = 'rgba(10, 10, 10, 0.95)';
      nav!.style.backdropFilter = 'blur(10px)';
      nav!.style.borderBottom = '1px solid rgba(201, 169, 110, 0.1)';
    } else {
      nav!.style.background = 'transparent';
      nav!.style.backdropFilter = 'none';
      nav!.style.borderBottom = 'none';
    }
  });

  // Mobile toggle
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
