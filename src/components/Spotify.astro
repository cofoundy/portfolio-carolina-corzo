---
import { siteConfig } from "../config";
---

<section id="playlist" class="py-20 sm:py-28 relative" style="background: var(--color-surface);">
  <div class="max-w-4xl mx-auto px-6">
    <!-- Section header -->
    <div class="reveal mb-12">
      <div class="flex items-center gap-4 mb-3">
        <p class="font-mono text-xs tracking-[0.3em] uppercase" style="color: var(--color-accent);">
          Now Playing
        </p>
        <!-- Equalizer bars -->
        <div class="flex items-end gap-0.5 h-4">
          <div class="eq-bar" style="animation-delay: 0s; height: 30%;"></div>
          <div class="eq-bar" style="animation-delay: 0.2s; height: 60%;"></div>
          <div class="eq-bar" style="animation-delay: 0.4s; height: 20%;"></div>
          <div class="eq-bar" style="animation-delay: 0.6s; height: 80%;"></div>
          <div class="eq-bar" style="animation-delay: 0.8s; height: 40%;"></div>
        </div>
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl tracking-wider" style="color: var(--color-surface-light);">
        SONGS I HELPED BRING TO LIFE
      </h2>
      <div class="gold-shimmer mt-4 w-24"></div>
    </div>

    <!-- Description -->
    <p class="reveal text-sm sm:text-base leading-relaxed mb-8 max-w-2xl" style="color: var(--color-surface-light); opacity: 0.6;">
      {siteConfig.spotify.description}
    </p>

    <!-- Track count badge -->
    <div class="reveal mb-8">
      <span class="inline-flex items-center gap-2 font-mono text-xs tracking-widest px-4 py-2 rounded-full border" style="color: var(--color-accent); border-color: var(--color-accent); opacity: 0.8;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18V5l12-2v13"/>
          <circle cx="6" cy="18" r="3"/>
          <circle cx="18" cy="16" r="3"/>
        </svg>
        {siteConfig.spotify.trackCount} canciones
      </span>
    </div>

    <!-- Spotify embed -->
    <div class="reveal-scale rounded-xl overflow-hidden" style="border: 1px solid var(--color-primary-light);">
      <iframe
        style="border-radius: 12px;"
        src={siteConfig.spotify.playlistUrl}
        width="100%"
        height="452"
        frameBorder="0"
        allowfullscreen=""
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>
